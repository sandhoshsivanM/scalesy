---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ClientRoster from '../components/ClientRoster.astro';
import Proof from '../components/Proof.astro';
import Manifesto from '../components/Manifesto.astro';
import Studio from '../components/Studio.astro';
import Services from '../components/Services.astro';
import System from '../components/System.astro';
import SelectedWork from '../components/SelectedWork.astro';
import BrandMoment from '../components/BrandMoment.astro';
import Process from '../components/Process.astro';
import Engagement from '../components/Engagement.astro';
import InsightsList from '../components/InsightsList.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactCTA from '../components/ContactCTA.astro';
---
<Base>
  <Hero />
  <ClientRoster />
  <Proof />
  <Manifesto />
  <Studio index="03" />
  <Services />
  <System />
  <SelectedWork eyebrowIndex="05" />
  <BrandMoment />
  <Process />
  <Engagement index="07" />
  <InsightsList index="08" limit={3} />
  <Testimonials />
  <ContactCTA index="10" />
</Base>
