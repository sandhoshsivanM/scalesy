---
import Base from '../../layouts/Base.astro';
import SelectedWork from '../../components/SelectedWork.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { work } from '../../data/work.js';
---
<Base title="Work — Scalesy" description="Selected engagements from Scalesy — brand strategy, design, and measurable growth.">
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow eyebrow--index" data-reveal>Selected Work</p>
      <h1 class="page-head__title" data-reveal-lines>
        <span class="line"><span>The work, and the</span></span>
        <span class="line"><span>thinking behind it.</span></span>
      </h1>
      <p class="page-head__lead measure text-secondary" data-reveal style="--reveal-delay:200ms">
        We take on a small number of engagements each year. These are a few that
        still hold up — not because of how they look, but because of the decisions
        underneath them.
      </p>
      <div class="rule-ticked page-head__rule" aria-hidden="true"></div>
    </div>
  </section>

  <SelectedWork items={work} showHeader={false} />
  <ContactCTA />
</Base>
