---
import Base from '../../layouts/Base.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { work } from '../../data/work.js';
import { withBase } from '../../lib/paths.js';

export function getStaticPaths() {
  return work.map((project, i) => ({
    params: { slug: project.slug },
    props: { project, next: work[(i + 1) % work.length] },
  }));
}

const { project, next } = Astro.props;
---
<Base
  title={`${project.name} — Scalesy`}
  description={project.excerpt}
>
  <article class="project">
    <header class="project-head">
      <div class="wrap">
        <a href={withBase('/work')} class="link-underline project-head__back">← All work</a>
        <p class="eyebrow eyebrow--index project-head__eyebrow" data-reveal>
          {project.industry} · {project.year}
        </p>
        <h1 class="project-head__title" data-reveal-lines>
          <span class="line"><span>{project.name}</span></span>
        </h1>
        <p class="project-head__intro measure" data-reveal style="--reveal-delay:180ms">
          {project.intro}
        </p>

        <dl class="project-head__facts" data-reveal style="--reveal-delay:260ms">
          <div>
            <dt>Industry</dt>
            <dd>{project.industry}</dd>
          </div>
          <div>
            <dt>Services</dt>
            <dd>{project.services.join(', ')}</dd>
          </div>
          <div>
            <dt>Year</dt>
            <dd>{project.year}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="wrap">
      <figure class="project-cover img-reveal">
        <img src={project.image} alt={`${project.name} — ${project.industry}`} width="1600" height="900" />
      </figure>
    </div>

    <div class="wrap">
      <div class="project-body">
        {project.sections.map((s, i) => (
          <section class="project-block" data-reveal style={`--reveal-delay:${i * 60}ms`}>
            <h2 class="project-block__heading">{s.heading}</h2>
            <p class="project-block__body">{s.body}</p>
          </section>
        ))}
      </div>
    </div>

    {project.outcome && (
      <div class="wrap">
        <blockquote class="project-outcome" data-reveal>
          <span class="project-outcome__label">Outcome</span>
          <p class="project-outcome__text">{project.outcome}</p>
        </blockquote>
      </div>
    )}

    <div class="wrap">
      <a class="project-next" href={withBase(`/work/${next.slug}`)}>
        <span class="project-next__label">Next project</span>
        <span class="project-next__name">{next.name}</span>
        <span class="project-next__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </article>

  <ContactCTA />
</Base>

<style>
  .project-head {
    padding-top: clamp(2.5rem, 7vh, 5rem);
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .project-head__back {
    display: inline-block;
    font-size: var(--step--1);
    color: var(--text-secondary);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .project-head__eyebrow { margin-bottom: 1.6rem; }
  .project-head__title {
    font-size: var(--step-4);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 450;
  }
  .project-head__intro {
    margin-top: clamp(1.8rem, 4vw, 2.6rem);
    font-size: var(--step-1);
    line-height: 1.4;
    color: var(--text);
  }
  .project-head__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem 3.5rem;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .project-head__facts dt {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }
  .project-head__facts dd { margin: 0; font-size: var(--step-0); }

  .project-cover {
    margin-block: clamp(1rem, 3vw, 2rem) clamp(4rem, 9vw, 7rem);
    aspect-ratio: 16 / 9;
  }
  .project-cover img { width: 100%; height: 100%; object-fit: cover; }

  .project-body {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
    max-width: 62rem;
  }
  .project-block {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(0, 3fr);
    gap: clamp(1rem, 3vw, 3rem);
    align-items: baseline;
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--line-faint);
  }
  .project-block__heading {
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    color: var(--accent);
    font-weight: 450;
  }
  .project-block__body {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--text);
    max-width: 46ch;
  }

  .project-outcome {
    margin: clamp(4rem, 9vw, 7rem) 0 0;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    max-width: 46rem;
  }
  .project-outcome__label {
    display: block;
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
  }
  .project-outcome__text {
    font-family: var(--font-display);
    font-size: var(--step-3);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0;
  }

  .project-next {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-top: clamp(4rem, 9vw, 7rem);
    padding-top: 2.4rem;
    border-top: 1px solid var(--line);
  }
  .project-next__label {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .project-next__name {
    font-family: var(--font-display);
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    transition: transform 0.5s var(--ease), color 0.4s var(--ease);
  }
  .project-next__arrow { color: var(--accent); transition: transform 0.4s var(--ease); }
  .project-next:hover .project-next__name { transform: translateX(6px); color: var(--accent); }
  .project-next:hover .project-next__arrow { transform: translateX(6px); }

  @media (max-width: 760px) {
    .project-block { grid-template-columns: 1fr; gap: 0.8rem; }
    .project-next { flex-wrap: wrap; gap: 0.6rem 1rem; }
    .project-next__name { flex-basis: 100%; }
  }
</style>
