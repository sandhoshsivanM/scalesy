---
import Base from '../../layouts/Base.astro';
import InsightsList from '../../components/InsightsList.astro';
import ContactCTA from '../../components/ContactCTA.astro';
---
<Base title="Insights — Scalesy" description="Writing on strategy, growth, and craft from the Scalesy studio.">
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow eyebrow--index" data-reveal>Insights</p>
      <h1 class="page-head__title" data-reveal-lines>
        <span class="line"><span>Notes on strategy,</span></span>
        <span class="line"><span>growth, and craft.</span></span>
      </h1>
      <p class="page-head__lead measure text-secondary" data-reveal style="--reveal-delay:200ms">
        Occasional writing on how we think about the work — published when we
        have something worth saying, not on a schedule.
      </p>
      <div class="rule-ticked page-head__rule" aria-hidden="true"></div>
    </div>
  </section>

  <InsightsList showHeader={false} />
  <ContactCTA />
</Base>
