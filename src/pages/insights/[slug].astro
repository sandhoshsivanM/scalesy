---
import Base from '../../layouts/Base.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { insights } from '../../data/insights.js';
import { withBase } from '../../lib/paths.js';

export function getStaticPaths() {
  return insights.map((article, i) => ({
    params: { slug: article.slug },
    props: { article, next: insights[(i + 1) % insights.length] },
  }));
}

const { article, next } = Astro.props;
const fmtDate = (iso) =>
  new Date(iso + 'T00:00:00Z').toLocaleDateString('en-US', {
    day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC',
  });
---
<Base title={`${article.title} — Scalesy`} description={article.excerpt}>
  <article class="article">
    <header class="article-head">
      <div class="wrap">
        <a href={withBase('/insights')} class="link-underline article-head__back">← All writing</a>
        <p class="eyebrow eyebrow--index article-head__meta" data-reveal>
          {article.category} · {fmtDate(article.date)} · {article.readingTime}
        </p>
        <h1 class="article-head__title measure" data-reveal>{article.title}</h1>
        <div class="rule article-head__rule" role="separator" aria-hidden="true"></div>
      </div>
    </header>

    <div class="wrap">
      <div class="article-body">
        <p class="article-body__lead" data-reveal>{article.excerpt}</p>
        {article.body.map((para, i) => (
          <p class="article-body__p" data-reveal style={`--reveal-delay:${Math.min(i, 4) * 40}ms`}>{para}</p>
        ))}
      </div>

      <a class="article-next" href={withBase(`/insights/${next.slug}`)}>
        <span class="article-next__label">Next</span>
        <span class="article-next__name">{next.title}</span>
        <span class="article-next__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </article>

  <ContactCTA />
</Base>

<style>
  .article-head {
    padding-top: clamp(2.5rem, 7vh, 5rem);
    padding-bottom: clamp(1rem, 3vw, 2rem);
  }
  .article-head__back {
    display: inline-block;
    font-size: var(--step--1);
    color: var(--text-secondary);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .article-head__meta { margin-bottom: 1.8rem; }
  .article-head__title {
    font-size: var(--step-3);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 450;
  }
  .article-head__rule { margin-top: clamp(3rem, 6vw, 4.5rem); }

  .article-body {
    max-width: 40rem;
    margin-block: clamp(3rem, 6vw, 4.5rem) 0;
  }
  .article-body__lead {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .article-body__p {
    font-size: var(--step-1);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 1.6rem;
  }
  .article-body__p:last-of-type { margin-bottom: 0; }

  .article-next {
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    max-width: 40rem;
    margin-top: clamp(4rem, 8vw, 6rem);
    padding-top: 2.2rem;
    border-top: 1px solid var(--line);
  }
  .article-next__label {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .article-next__name {
    font-family: var(--font-display);
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    transition: color 0.4s var(--ease);
  }
  .article-next__arrow { color: var(--accent); margin-left: auto; }
  .article-next:hover .article-next__name { color: var(--accent); }
</style>
