---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/paths.js';
import ChatWidget from '../components/ChatWidget.astro';

const {
  title = 'SCALESY — Measure. Scale. Grow.',
  description = 'A marketing and branding studio building brands with precision, strategy, and measurable growth.',
} = Astro.props;

const ogImage = new URL(withBase('/brand/og-image.jpg'), Astro.site);

// @font-face lives here (not global.css) so the src URLs can carry the base.
const fontFace = ['Light 300', 'Regular 400 450', 'Medium 500', 'Bold 700']
  .map((w) => {
    const [name, ...wt] = w.split(' ');
    return `@font-face{font-family:'Neue Montreal';src:url('${withBase(`/fonts/NeueMontreal-${name}.otf`)}') format('opentype');font-weight:${wt.join(' ')};font-style:normal;font-display:swap;}`;
  })
  .join('');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Theme init BEFORE paint (no flash). Default: dark (black + gold).
      // Honors a saved choice, else the OS preference.
      (function () {
        try {
          var saved = localStorage.getItem('scalesy-theme');
          var theme = saved || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
        } catch (e) {}
      })();

      // Scroll-reveal, inlined so it always runs alongside the `.js` gate
      // (no dependency on the deferred bundle). Content is visible by default
      // without JS; hidden→shown only when this runs.
      document.documentElement.classList.add('js');
      (function () {
        var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        function reveal(el) { el.classList.add('is-visible'); }
        function init() {
          var els = document.querySelectorAll('[data-reveal],[data-reveal-lines],.img-reveal');
          if (reduce || !('IntersectionObserver' in window)) {
            els.forEach(reveal);
            return;
          }
          var io = new IntersectionObserver(function (entries, obs) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { reveal(e.target); obs.unobserve(e.target); }
            });
          }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
          els.forEach(function (el) { io.observe(el); });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else { init(); }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />

    <!-- Favicons / touch icons -->
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32.png')} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('/brand/apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />

    <!-- Open Graph / social share -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Self-hosted display font (@font-face src carries the base) -->
    <style is:global set:html={fontFace}></style>

    <!-- Preload display font (kills flash-of-unstyled-text on headings) -->
    <link rel="preload" as="font" type="font/otf" href={withBase('/fonts/NeueMontreal-Regular.otf')} crossorigin />
    <link rel="preload" as="font" type="font/otf" href={withBase('/fonts/NeueMontreal-Medium.otf')} crossorigin />

    <!-- Inter (body), from Fontshare. Neue Montreal (display) is self-hosted. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=inter@400,500&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ChatWidget />
    <script src="../scripts/main.js"></script>
  </body>
</html>
