---
// Hero — two-column editorial: statement left, measurement graphic right.
import { withBase } from '../lib/paths.js';
import GrowthPlot from './graphics/GrowthPlot.astro';
import Tagline from './Tagline.astro';
---
<section class="hero" aria-label="Introduction">
  <div class="wrap hero__inner">
    <div class="hero__lead">
      <p class="eyebrow hero__eyebrow" data-reveal>Marketing &amp; Branding Studio</p>

      <h1 class="hero__headline" data-reveal-lines>
        <span class="line"><span>Measure.</span></span>
        <span class="line"><span>Scale.</span></span>
        <span class="line"><span>Grow.</span></span>
      </h1>

      <div class="hero__tagline" data-reveal style="--reveal-delay:160ms">
        <Tagline align="start" />
      </div>

      <p class="hero__sub measure" data-reveal style="--reveal-delay:240ms">
        Building brands with precision, strategy, and measurable growth.
      </p>

      <div class="hero__actions" data-reveal style="--reveal-delay:300ms">
        <a href={withBase('/contact')} class="cta hero__cta">
          <span>Book a Discovery Call</span>
          <span class="cta__arrow" aria-hidden="true">→</span>
          <span class="cta__bar"></span>
        </a>
      </div>

      <div class="hero__meta" data-reveal style="--reveal-delay:360ms">
        <span>Studio — Chennai, Tamil Nadu</span>
        <span>Working across South India</span>
        <span class="hero__meta-est">Est. MMXIX</span>
      </div>
    </div>

    <div class="hero__figure">
      <GrowthPlot />
    </div>
  </div>

  <div class="wrap">
    <div class="rule-ticked hero__rule" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 8vh, 6rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1rem, 3vw, 3rem);
    align-items: center;
  }

  .hero__lead {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero__eyebrow { margin-bottom: clamp(1.6rem, 4vw, 2.6rem); }

  .hero__headline {
    font-size: clamp(3rem, 1.6rem + 7vw, 6.4rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
    font-weight: 450;
  }
  .hero__tagline { margin-top: clamp(1.6rem, 3vw, 2.2rem); align-self: stretch; max-width: 30rem; }
  .hero__sub {
    margin-top: clamp(1.4rem, 2.6vw, 2rem);
    font-size: var(--step-1);
    line-height: 1.4;
    color: var(--text);
  }
  .hero__actions { margin-top: clamp(1.8rem, 3vw, 2.6rem); }

  .hero__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: clamp(2.4rem, 5vw, 3.6rem);
    padding-top: 1.4rem;
    border-top: 1px solid var(--line-faint);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }
  .hero__meta-est { color: var(--accent); letter-spacing: 0.14em; }

  .hero__figure {
    grid-column: 8 / -1;
    align-self: center;
    padding-left: clamp(0rem, 2vw, 2rem);
  }

  .hero__rule { margin-top: clamp(1.8rem, 4vw, 3rem); }

  @media (max-width: 900px) {
    .hero__lead { grid-column: 1 / -1; }
    .hero__figure {
      grid-column: 1 / -1;
      margin-top: clamp(2.5rem, 6vw, 4rem);
      max-width: 26rem;
    }
  }
</style>
