---
// Hero — conversion split: statement + proof + CTA (left), lead form card (right).
import { withBase } from '../lib/paths.js';
import Tagline from './Tagline.astro';
import HeroForm from './HeroForm.astro';

const pills = ['Strategy before craft', 'A few engagements a year', 'Measurable by design'];
---
<section class="hero" aria-label="Introduction">
  <div class="wrap hero__inner">
    <div class="hero__lead">
      <div class="hero__eyebrow" data-reveal><Tagline align="start" /></div>

      <h1 class="hero__headline" data-reveal-lines>
        <span class="line"><span>Measure.</span></span>
        <span class="line"><span>Scale.</span></span>
        <span class="line"><span>Grow.</span></span>
      </h1>

      <p class="hero__sub measure" data-reveal style="--reveal-delay:200ms">
        A branding studio for companies that would rather be understood than merely
        seen. We do the thinking first — and let measurable growth follow from it.
      </p>

      <ul class="hero__pills" data-reveal style="--reveal-delay:280ms">
        {pills.map((p) => <li class="pill">{p}</li>)}
      </ul>

      <div class="hero__actions" data-reveal style="--reveal-delay:340ms">
        <a href={withBase('/contact')} class="btn">Book a Discovery Call <span class="btn__arrow" aria-hidden="true">→</span></a>
        <a href={withBase('/work')} class="btn btn--ghost">View our work</a>
      </div>

      <div class="hero__meta" data-reveal style="--reveal-delay:400ms">
        <span>Studio — Chennai, Tamil Nadu</span>
        <span>Working across South India</span>
        <span class="hero__meta-est">Est. MMXIX</span>
      </div>
    </div>

    <div class="hero__form" data-reveal style="--reveal-delay:160ms">
      <HeroForm />
    </div>
  </div>

  <div class="wrap">
    <div class="rule-ticked hero__rule" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(2.5rem, 6vh, 4.5rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  .hero__lead {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero__eyebrow { margin-bottom: clamp(1.4rem, 3vw, 2.2rem); max-width: 30rem; align-self: stretch; }

  .hero__headline {
    font-size: clamp(2.8rem, 1.4rem + 6.6vw, 6rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
    font-weight: 450;
  }
  .hero__sub {
    margin-top: clamp(1.4rem, 2.6vw, 2rem);
    font-size: var(--step-1);
    line-height: 1.42;
    color: var(--text);
    max-width: 40ch;
  }

  .hero__pills {
    list-style: none; margin: clamp(1.6rem, 3vw, 2.2rem) 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.6rem;
  }
  .pill {
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.5rem 0.95rem;
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .pill::before { content: ""; width: 5px; height: 5px; border-radius: 50%; background: var(--gold); }

  .hero__actions {
    margin-top: clamp(1.8rem, 3vw, 2.4rem);
    display: flex; flex-wrap: wrap; gap: 0.8rem;
  }

  .hero__meta {
    display: flex; flex-direction: column; gap: 0.35rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: 1.4rem;
    border-top: 1px solid var(--line-faint);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }
  .hero__meta-est { color: var(--accent); letter-spacing: 0.14em; }

  .hero__form { grid-column: 8 / -1; align-self: center; }

  .hero__rule { margin-top: clamp(2rem, 4vw, 3rem); }

  @media (max-width: 960px) {
    .hero__lead { grid-column: 1 / -1; }
    .hero__form { grid-column: 1 / -1; margin-top: clamp(2.5rem, 6vw, 3.5rem); max-width: 30rem; }
  }
</style>
