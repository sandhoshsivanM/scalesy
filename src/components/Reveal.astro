---
// Fade + rise on scroll. `delay` staggers grouped reveals (ms).
// `as` sets the wrapper element; `lines` switches to the masked line-reveal mode.
const { as = 'div', delay = 0, lines = false, class: className = '' } = Astro.props;
const Tag = as;
const style = delay ? `--reveal-delay:${delay}ms` : undefined;
---
<Tag
  class:list={[className]}
  data-reveal={lines ? undefined : ''}
  data-reveal-lines={lines ? '' : undefined}
  style={style}
>
  <slot />
</Tag>
