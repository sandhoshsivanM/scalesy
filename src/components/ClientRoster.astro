---
import { clients } from '../data/clients.js';
---
<section class="roster" aria-label="Selected clients">
  <div class="wrap">
    <div class="roster__inner" data-reveal>
      <p class="roster__label">Trusted across Tamil Nadu by</p>
      <ul class="roster__list">
        {clients.map((name) => (
          <li class="roster__item">{name}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .roster { padding-block: clamp(2.25rem, 4vw, 3.25rem); }
  .roster__inner {
    display: grid;
    grid-template-columns: minmax(0, auto) 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: baseline;
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--line);
  }
  .roster__label {
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .roster__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem clamp(1.4rem, 3vw, 2.6rem);
  }
  .roster__item {
    font-family: var(--font-display);
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    color: var(--text);
    position: relative;
    padding-right: clamp(1.4rem, 3vw, 2.6rem);
  }
  .roster__item:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 3px;
    background: var(--accent);
    border-radius: 50%;
  }

  @media (max-width: 720px) {
    .roster__inner { grid-template-columns: 1fr; }
    .roster__item { font-size: var(--step-0); }
  }
</style>
