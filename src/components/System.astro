---
import { disciplines } from '../data/system.js';
---
<section class="section system" id="system" aria-labelledby="system-label">
  <div class="wrap">
    <div class="system__head" data-reveal>
      <p class="eyebrow eyebrow--index" id="system-label"><span>—</span>&nbsp;&nbsp;The System</p>
      <h2 class="system__title">Four disciplines.<br />One connected engine.</h2>
      <p class="system__note text-secondary measure-narrow">
        We don’t sell services in isolation. Each discipline feeds the next — and
        what we learn at the end returns to the start.
      </p>
    </div>

    <div class="system" data-system>
      <ol class="system__tabs" role="tablist" aria-label="Disciplines">
        {disciplines.map((d, i) => (
          <li>
            <button
              class="system__tab"
              role="tab"
              data-tab={d.key}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${d.key}`}
              id={`tab-${d.key}`}
            >
              <span class="system__tab-n">{d.n}</span>
              <span class="system__tab-title">{d.title}</span>
              <span class="system__tab-line" aria-hidden="true"></span>
            </button>
          </li>
        ))}
      </ol>

      <div class="system__panels">
        {disciplines.map((d, i) => (
          <div
            class="system-panel"
            data-panel={d.key}
            role="tabpanel"
            id={`panel-${d.key}`}
            aria-labelledby={`tab-${d.key}`}
            data-active={i === 0 ? '' : undefined}
            hidden={i !== 0}
          >
            <p class="system-panel__index">{d.n} / 04</p>
            <h3 class="system-panel__title">{d.title}</h3>
            <p class="system-panel__tagline">{d.tagline}</p>
            <p class="system-panel__body text-secondary">{d.body}</p>
            <ul class="system-panel__caps">
              {d.caps.map((c) => <li>{c}</li>)}
            </ul>
            <p class="system-panel__feeds"><span>Connects —</span> {d.feeds}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .system__head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 1.5rem clamp(1.5rem, 4vw, 4rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .system__head .eyebrow { grid-column: 1 / -1; margin-bottom: 0.5rem; }
  .system__title { grid-column: 1 / 8; font-size: var(--step-2); letter-spacing: -0.025em; line-height: 1.02; }
  .system__note { grid-column: 8 / -1; font-size: var(--step-0); }

  .system {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    border-top: 1px solid var(--line);
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .system__tabs { list-style: none; margin: 0; padding: 0; }
  .system__tab {
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: 2.4rem 1fr;
    align-items: baseline;
    gap: 0.9rem;
    background: none;
    border: 0;
    text-align: left;
    cursor: pointer;
    padding: clamp(1rem, 2vw, 1.4rem) 0;
    border-top: 1px solid var(--line-faint);
    color: var(--text-secondary);
    transition: color 0.35s var(--ease);
  }
  .system__tabs li:first-child .system__tab { border-top: 0; }
  .system__tab-n { font-size: var(--step--1); letter-spacing: 0.1em; color: var(--accent); }
  .system__tab-title { font-family: var(--font-display); font-size: var(--step-1); letter-spacing: -0.01em; transition: transform 0.4s var(--ease); }
  .system__tab-line {
    position: absolute; left: 0; top: -1px; height: 1px; width: 0; background: var(--accent);
    transition: width 0.5s var(--ease);
  }
  .system__tab:hover { color: var(--text); }
  .system__tab[aria-selected='true'] { color: var(--text); }
  .system__tab[aria-selected='true'] .system__tab-title { transform: translateX(4px); }
  .system__tab[aria-selected='true'] .system__tab-line { width: 100%; }

  .system__panels { position: relative; }
  .system-panel { }
  .system-panel[hidden] { display: none; }
  .system-panel__index { font-size: var(--step--1); letter-spacing: 0.12em; color: var(--accent); }
  .system-panel__title { font-size: var(--step-3); letter-spacing: -0.03em; line-height: 1; margin-top: 0.8rem; }
  .system-panel__tagline { font-family: var(--font-display); font-size: var(--step-1); color: var(--text); margin-top: 0.8rem; }
  .system-panel__body { font-size: var(--step-0); line-height: 1.6; margin-top: 1rem; max-width: 48ch; }
  .system-panel__caps {
    list-style: none; margin: clamp(1.6rem, 3vw, 2.2rem) 0 0; padding: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border-top: 1px solid var(--line);
  }
  .system-panel__caps li {
    padding: 0.9rem 0;
    font-size: var(--step-0);
    color: var(--text);
    border-bottom: 1px solid var(--line-faint);
    position: relative;
    padding-left: 1.2rem;
  }
  .system-panel__caps li::before { content: ""; position: absolute; left: 0; top: 1.3rem; width: 6px; height: 1px; background: var(--gold); }
  .system-panel__feeds {
    margin-top: clamp(1.4rem, 3vw, 2rem);
    font-size: var(--step--1);
    color: var(--text-secondary);
  }
  .system-panel__feeds span { color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; }

  /* enter animation on tab change (JS toggles data-active) */
  .system-panel[data-active] { animation: system-in 0.5s var(--ease); }
  @keyframes system-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .system-panel[data-active] { animation: none; } }

  @media (max-width: 860px) {
    .system__title, .system__note { grid-column: 1 / -1; }
    .system { grid-template-columns: 1fr; }
    .system-panel__caps { grid-template-columns: 1fr; }
  }
</style>
