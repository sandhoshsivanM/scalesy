---
// Compact lead-capture card for the hero. Posts to the same Google Form as the
// full BookingForm and reuses the same data-* hooks, so main.js `initBooking`
// drives validation + submission. (Only one [data-booking] form exists per page.)
import { bookingForm, isConfigured } from '../data/bookingForm.js';
const configured = isConfigured();
const action = configured
  ? `https://docs.google.com/forms/d/e/${bookingForm.formId}/formResponse`
  : '';
const e = bookingForm.entries;
---
<form
  class="lead"
  data-booking
  data-action={action}
  data-configured={configured ? 'true' : 'false'}
  action={action}
  method="POST"
  target="scalesy-gform-sink"
  novalidate
>
  <div class="lead__head">
    <p class="lead__eyebrow">Book a discovery call</p>
    <p class="lead__note text-secondary">A 45-minute conversation about the business, not the brief.</p>
  </div>

  <div class="lead__fields">
    <div class="field">
      <input class="field__input" id="lf-name" name={e.name} type="text" placeholder="Your name" autocomplete="name" data-field="name" required />
      <span class="field__error" data-error hidden></span>
    </div>
    <div class="field">
      <input class="field__input" id="lf-email" name={e.email} type="email" placeholder="Work email" autocomplete="email" data-field="email" required />
      <span class="field__error" data-error hidden></span>
    </div>
    <div class="field">
      <input class="field__input" id="lf-phone" name={e.phone} type="tel" placeholder="Phone" autocomplete="tel" data-field="phone" required />
      <span class="field__error" data-error hidden></span>
    </div>
    <div class="field field__select-wrap">
      <select class="field__input field__select" name={e.service} data-field="service" aria-label="What can we help with?">
        {bookingForm.serviceOptions.map((opt) => <option value={opt}>{opt}</option>)}
      </select>
      <span class="field__chev" aria-hidden="true">↓</span>
    </div>
  </div>

  <button type="submit" class="btn lead__submit" data-submit>
    <span class="booking__submit-label">Request my call</span>
    <span class="btn__arrow" aria-hidden="true">→</span>
  </button>
  <p class="lead__fine text-secondary">No obligation. We reply within two working days.</p>

  <div class="lead__success" data-success hidden role="status" aria-live="polite">
    <p class="lead__success-mark" aria-hidden="true">✓</p>
    <h3 class="lead__success-title">Your request is in.</h3>
    <p class="text-secondary">We’ll be in touch shortly to arrange your call.</p>
  </div>

  {!configured && (
    <p class="lead__demo" data-demo>Demo mode — connect a Google Form in <code>src/data/bookingForm.js</code>.</p>
  )}
</form>
<iframe name="scalesy-gform-sink" class="lead__sink" title="form sink" aria-hidden="true" tabindex="-1"></iframe>

<style>
  .lead {
    position: relative;
    background: var(--bg-raise);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: clamp(1.5rem, 3vw, 2.2rem);
  }
  .lead__head { margin-bottom: 1.4rem; }
  .lead__eyebrow {
    font-family: var(--font-display);
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .lead__note { font-size: var(--step--1); margin-top: 0.4rem; line-height: 1.45; }

  .lead__fields { display: flex; flex-direction: column; gap: 0.7rem; }
  .field { display: flex; flex-direction: column; }
  .field__input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 9px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--step-0);
    padding: 0.8rem 0.95rem;
    transition: border-color 0.3s var(--ease);
  }
  .field__input::placeholder { color: var(--text-secondary); }
  .field__input:focus { outline: none; border-color: var(--accent); }
  .field__select-wrap { position: relative; }
  .field__select { appearance: none; -webkit-appearance: none; cursor: pointer; padding-right: 2rem; }
  .field__select option { background: var(--bg); color: var(--text); }
  .field__chev { position: absolute; right: 0.9rem; top: 0.85rem; color: var(--accent); pointer-events: none; }
  .field__error { font-size: var(--step--1); color: #c0562f; margin-top: 0.35rem; }
  .field.is-invalid .field__input { border-color: #c0562f; }

  .lead__submit { width: 100%; justify-content: center; margin-top: 1rem; padding-block: 0.95rem; }
  .lead__fine { font-size: 0.72rem; text-align: center; margin-top: 0.8rem; letter-spacing: 0.02em; }

  .lead__success {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
    gap: 0.7rem; padding: 2rem;
    background: var(--bg-raise); border-radius: 14px;
  }
  .lead__success[hidden] { display: none; }
  .lead__success-mark {
    width: 2.6rem; height: 2.6rem; display: grid; place-items: center;
    border: 1px solid var(--accent); border-radius: 50%; color: var(--accent);
  }
  .lead__success-title { font-size: var(--step-1); }
  .lead__demo { margin-top: 0.9rem; font-size: var(--step--1); color: var(--text-secondary); text-align: center; }
  .lead__demo code { color: var(--accent); font-family: ui-monospace, Menlo, monospace; font-size: 0.85em; }
  .lead__sink { display: none; }
</style>
