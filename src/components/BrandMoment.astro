---
import { withBase } from '../lib/paths.js';
import Tagline from './Tagline.astro';
---
<section class="brand-moment" aria-label="Scalesy">
  <div class="wrap">
    <div class="rule-ticked" aria-hidden="true"></div>

    <div class="brand-moment__inner" data-reveal>
      <img
        class="brand-moment__mark"
        src={withBase('/brand/scalesy-mark.png')}
        alt="Scalesy mark"
        width="530"
        height="763"
        loading="lazy"
      />
      <p class="brand-moment__statement">Precision is the product.</p>
      <div class="brand-moment__tagline"><Tagline align="center" /></div>
    </div>

    <div class="rule-ticked" aria-hidden="true"></div>
  </div>
</section>

<style>
  .brand-moment { padding-block: clamp(2rem, 5vw, 4rem); }
  .brand-moment__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.6rem, 3.5vw, 2.6rem);
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .brand-moment__mark {
    height: clamp(9rem, 18vw, 15rem);
    width: auto;
    filter: drop-shadow(0 4px 22px rgba(0, 0, 0, 0.5));
  }
  .brand-moment__statement {
    font-family: var(--font-display);
    font-size: var(--step-3);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text);
    font-weight: 450;
  }
  .brand-moment__tagline { width: min(30rem, 90%); }
</style>
