---
// SCALESY tagline lockup — "We scale brands digitally" in gold caps, flanked
// by hairline gold rules (mirrors the brand artwork). `align` = start | center.
const { align = 'start', text = 'We scale brands digitally' } = Astro.props;
---
<p class={`tagline tagline--${align}`}>
  <span class="tagline__rule tagline__rule--lead" aria-hidden="true"></span>
  <span class="tagline__text">{text}</span>
  <span class="tagline__rule tagline__rule--trail" aria-hidden="true"></span>
</p>

<style>
  .tagline {
    display: flex;
    align-items: center;
    gap: clamp(0.9rem, 2vw, 1.4rem);
    margin: 0;
  }
  .tagline__text {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }
  .tagline__rule { height: 1px; background: var(--line); }

  /* left-anchored: short lead rule, trailing rule fills remaining width */
  .tagline--start .tagline__rule--lead { width: 2.4rem; flex: none; }
  .tagline--start .tagline__rule--trail { flex: 1; }

  /* centred: both rules flex equally (the artwork lockup) */
  .tagline--center { justify-content: center; }
  .tagline--center .tagline__rule { flex: 1; max-width: 5rem; }

  @media (max-width: 520px) {
    .tagline__text { letter-spacing: 0.16em; white-space: normal; }
  }
</style>
