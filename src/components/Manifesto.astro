---
const principles = [
  { k: 'A', t: 'Clarity over volume' },
  { k: 'B', t: 'Margin over vanity' },
  { k: 'C', t: 'Consequence over noise' },
];
---
<section class="section manifesto" id="manifesto" aria-labelledby="manifesto-label">
  <div class="wrap manifesto__inner">
    <p class="eyebrow eyebrow--index manifesto__label" id="manifesto-label" data-reveal>
      <span>02</span>&nbsp;&nbsp;Manifesto
    </p>

    <div class="manifesto__body">
      <p class="manifesto__lead" data-reveal>
        We believe great marketing<br />
        isn’t louder. It’s smarter.
      </p>

      <div class="manifesto__side" data-reveal style="--reveal-delay:120ms">
        <p class="manifesto__coda">
          Every decision should have purpose. Every campaign should create
          measurable impact. We are not in the business of noise — we are in the
          business of consequence.
        </p>

        <div class="manifesto__principles">
          <p class="manifesto__principles-label">What we hold to</p>
          <ul>
            {principles.map((p) => (
              <li class="principle">
                <span class="principle__k">{p.k}</span>
                <span class="principle__t">{p.t}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .manifesto__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    row-gap: clamp(2.5rem, 6vw, 4.5rem);
  }
  .manifesto__label { grid-column: 1 / -1; }

  .manifesto__body {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
  }

  .manifesto__lead {
    grid-column: 1 / 8;
    font-family: var(--font-display);
    font-size: var(--step-3);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 450;
    color: var(--text);
  }

  .manifesto__side {
    grid-column: 8 / -1;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }
  .manifesto__coda {
    color: var(--text-secondary);
    font-size: var(--step-0);
    line-height: 1.65;
  }

  .manifesto__principles-label {
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.4rem;
  }
  .manifesto__principles ul { list-style: none; margin: 0; padding: 0; }
  .principle {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--line-faint);
  }
  .principle__k {
    font-size: var(--step--1);
    color: var(--accent);
    letter-spacing: 0.1em;
    width: 1.2rem;
  }
  .principle__t {
    font-family: var(--font-display);
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    color: var(--text);
  }

  @media (max-width: 900px) {
    .manifesto__lead { grid-column: 1 / -1; }
    .manifesto__side { grid-column: 1 / -1; }
  }
</style>
