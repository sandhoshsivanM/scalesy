---
const { index = '07' } = Astro.props;
const stages = [
  {
    n: '01',
    title: 'The first call',
    body: 'A conversation about the business, not the brief. We listen for what isn’t written down — and tell you honestly whether we’re the right studio for it.',
  },
  {
    n: '02',
    title: 'The engagement',
    body: 'A focused body of work with a clear scope and a single point of contact. We move at the pace of good decisions and keep you close to every one.',
  },
  {
    n: '03',
    title: 'What you receive',
    body: 'A strategy you could defend under questioning, the craft that expresses it, and the measurement to know it worked.',
  },
];
---
<section class="section engagement" id="engagement" aria-labelledby="engagement-label">
  <div class="wrap">
    <div class="engagement__head" data-reveal>
      <p class="eyebrow eyebrow--index" id="engagement-label">
        <span>{index}</span>&nbsp;&nbsp;How we work
      </p>
      <h2 class="engagement__title measure-narrow">
        A short, considered engagement — never a retainer on autopilot.
      </h2>
    </div>

    <ol class="engagement__grid">
      {stages.map((s, i) => (
        <li class="engagement__col" data-reveal style={`--reveal-delay:${i * 80}ms`}>
          <span class="engagement__n">{s.n}</span>
          <h3 class="engagement__col-title">{s.title}</h3>
          <p class="engagement__col-body text-secondary">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .engagement__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 3rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .engagement__title {
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .engagement__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    border-top: 1px solid var(--line);
    padding-top: clamp(2rem, 4vw, 3rem);
  }
  .engagement__col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-left: clamp(1.2rem, 3vw, 2.6rem);
    border-left: 1px solid var(--line-faint);
    position: relative;
  }
  .engagement__col::before {
    content: "";
    position: absolute;
    top: -1px; left: -1px;
    width: 1px; height: 2.4rem;
    background: var(--accent);
  }
  .engagement__col:first-child { padding-left: 0; border-left: 0; }
  .engagement__col:first-child::before { left: 0; }
  .engagement__n {
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .engagement__col-title {
    font-size: var(--step-2);
    letter-spacing: -0.02em;
  }
  .engagement__col-body { font-size: var(--step-0); line-height: 1.6; }

  @media (max-width: 820px) {
    .engagement__grid { grid-template-columns: 1fr; gap: 0; }
    .engagement__col {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid var(--line-faint);
      padding-block: clamp(1.6rem, 4vw, 2.2rem);
    }
    .engagement__col:first-child { border-top: 0; }
    .engagement__col::before { top: -1px; left: 0; width: 2.4rem; height: 1px; }
  }
</style>
