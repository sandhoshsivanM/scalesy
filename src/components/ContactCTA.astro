---
import { withBase } from '../lib/paths.js';
const { index = '08' } = Astro.props;
---
<section class="section contact-cta" id="contact-cta" aria-labelledby="cta-label">
  <div class="wrap">
    <div class="rule-ticked" aria-hidden="true"></div>
    <div class="contact-cta__inner">
      <div class="contact-cta__lead">
        <p class="eyebrow eyebrow--index" id="cta-label" data-reveal>
          <span>{index}</span>&nbsp;&nbsp;Contact
        </p>
        <h2 class="contact-cta__headline" data-reveal>
          Ready to build<br />something remarkable?
        </h2>
      </div>

      <div class="contact-cta__panel" data-reveal style="--reveal-delay:120ms">
        <dl class="contact-cta__coords">
          <div>
            <dt>Studio</dt>
            <dd>Chennai, India</dd>
          </div>
          <div>
            <dt>Coordinates</dt>
            <dd>13.0827° N&nbsp;&nbsp;80.2707° E</dd>
          </div>
          <div>
            <dt>Response</dt>
            <dd>Within two working days</dd>
          </div>
        </dl>

        <div class="contact-cta__action">
          <a href={withBase('/contact')} class="cta contact-cta__link">
            <span>Book a Discovery Call</span>
            <span class="cta__arrow" aria-hidden="true">→</span>
            <span class="cta__bar"></span>
          </a>
          <a href="mailto:hello@scalesy.com" class="link-underline contact-cta__email">hello@scalesy.com</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1.5rem, 4vw, 4rem);
    row-gap: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: clamp(3rem, 7vw, 5.5rem);
    align-items: start;
  }
  .contact-cta__lead { grid-column: 1 / 8; }
  .contact-cta__headline {
    margin-top: clamp(1.6rem, 3vw, 2.4rem);
    font-size: var(--step-3);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 450;
  }

  .contact-cta__panel {
    grid-column: 8 / -1;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }
  .contact-cta__coords { margin: 0; display: flex; flex-direction: column; }
  .contact-cta__coords > div {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--line-faint);
  }
  .contact-cta__coords > div:first-child { border-top: 1px solid var(--line); }
  .contact-cta__coords dt {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .contact-cta__coords dd { margin: 0; font-size: var(--step-0); color: var(--text); }

  .contact-cta__action { display: flex; flex-direction: column; align-items: flex-start; gap: 1.4rem; }
  .contact-cta__email { font-size: var(--step-0); color: var(--text-secondary); }

  @media (max-width: 900px) {
    .contact-cta__lead { grid-column: 1 / -1; }
    .contact-cta__panel { grid-column: 1 / -1; }
  }
</style>
