---
import { studio } from '../data/studio.js';
const { index = '03' } = Astro.props;
---
<section class="section studio" id="studio" aria-labelledby="studio-label">
  <div class="wrap studio__inner">
    <div class="studio__media-col">
      <figure class="studio__media img-reveal">
        <img src={studio.image} alt="Inside the Scalesy studio" loading="lazy" width="1400" height="1000" />
        <figcaption class="studio__figure-cap">{studio.founded}</figcaption>
      </figure>
    </div>

    <div class="studio__text">
      <p class="eyebrow eyebrow--index" id="studio-label" data-reveal>
        <span>{index}</span>&nbsp;&nbsp;Studio
      </p>
      <h2 class="studio__title" data-reveal>The people who measure, scale, and grow.</h2>

      <div class="studio__body" data-reveal style="--reveal-delay:120ms">
        {studio.statement.map((p) => <p>{p}</p>)}
      </div>

      {studio.founders.length > 0 ? (
        <ul class="studio__founders" data-reveal style="--reveal-delay:200ms">
          {studio.founders.map((f) => (
            <li class="studio__founder">
              <span class="studio__founder-name">{f.name}</span>
              <span class="studio__founder-role">{f.role}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="studio__signature" data-reveal style="--reveal-delay:200ms">— {studio.signature}</p>
      )}
    </div>
  </div>
</section>

<style>
  .studio__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }
  .studio__media-col { grid-column: 1 / 6; }
  .studio__media { position: relative; aspect-ratio: 4 / 5; margin: 0; }
  .studio__media img { width: 100%; height: 100%; object-fit: cover; }
  .studio__figure-cap {
    position: absolute;
    left: clamp(-1.4rem, -1.5vw, -1rem);
    bottom: clamp(1.4rem, 3vw, 2.2rem);
    background: var(--bg);
    border: 1px solid var(--line);
    padding: 0.8rem 1.2rem;
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .studio__text { grid-column: 7 / -1; }
  .studio__title {
    margin-top: clamp(1.6rem, 3vw, 2.4rem);
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .studio__body {
    margin-top: clamp(1.8rem, 3.5vw, 2.6rem);
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    color: var(--text-secondary);
    font-size: var(--step-0);
    line-height: 1.65;
    max-width: 54ch;
  }

  .studio__founders {
    list-style: none; margin: clamp(2rem, 4vw, 3rem) 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 1.2rem 3rem;
  }
  .studio__founder { display: flex; flex-direction: column; gap: 0.2rem; }
  .studio__founder-name { font-family: var(--font-display); font-size: var(--step-1); }
  .studio__founder-role { font-size: var(--step--1); letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }

  .studio__signature {
    margin-top: clamp(2rem, 4vw, 3rem);
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--text);
  }

  @media (max-width: 900px) {
    .studio__media-col { grid-column: 1 / -1; max-width: 26rem; }
    .studio__text { grid-column: 1 / -1; margin-top: clamp(2.5rem, 6vw, 3.5rem); }
  }
</style>
