---
// Measurement-inspired brand graphic: a precision plot with a tick grid and an
// ascending gold line (measure → scale → grow). Hairline gold only — no fills,
// gradients, or glow. The line draws in on scroll (subtle, respects reduced-motion).
const { label = true } = Astro.props;
// polyline vertices (ascending) within the 400 x 460 plot field
const pts = [[40,372],[110,338],[180,300],[250,232],[320,150],[380,72]];
const poly = pts.map((p) => p.join(',')).join(' ');
---
<div class="plot" data-reveal>
  <svg viewBox="0 0 400 460" class="plot__svg" role="img" aria-label="Growth plotted against precise measurement">
    <!-- faint horizontal gridlines -->
    <g class="plot__grid">
      {[80,152,224,296,368].map((y) => (
        <line x1="40" y1={y} x2="392" y2={y} />
      ))}
    </g>
    <!-- axes -->
    <line class="plot__axis" x1="40" y1="40" x2="40" y2="400" />
    <line class="plot__axis" x1="40" y1="400" x2="392" y2="400" />
    <!-- x ticks + numerals -->
    <g class="plot__ticks">
      {pts.map((p, i) => (
        <Fragment>
          <line x1={p[0]} y1="400" x2={p[0]} y2="408" />
          <text x={p[0]} y="424" class="plot__num">{`0${i + 1}`}</text>
        </Fragment>
      ))}
    </g>
    <!-- y ticks -->
    <g class="plot__ticks">
      {[400,328,256,184,112,40].map((y) => (
        <line x1="32" y1={y} x2="40" y2={y} />
      ))}
    </g>
    <!-- the growth line -->
    <polyline class="plot__line" points={poly} pathLength="1" />
    <!-- plotted nodes -->
    <g class="plot__nodes">
      {pts.map((p) => (
        <rect x={p[0] - 3.5} y={p[1] - 3.5} width="7" height="7" />
      ))}
    </g>
  </svg>
  {label && (
    <div class="plot__caption">
      <span>Fig. 01</span>
      <span>Growth, measured</span>
    </div>
  )}
</div>

<style>
  .plot { width: 100%; }
  .plot__svg { width: 100%; height: auto; display: block; overflow: visible; }

  .plot__grid line { stroke: var(--line-faint); stroke-width: 1; }
  .plot__axis { stroke: var(--line); stroke-width: 1; }
  .plot__ticks line { stroke: var(--accent); stroke-width: 1; opacity: 0.7; }
  .plot__num {
    fill: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-anchor: middle;
  }

  .plot__line {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.6;
    stroke-linejoin: round;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 1.8s var(--ease) 0.15s;
  }
  .plot.is-visible .plot__line { stroke-dashoffset: 0; }

  .plot__nodes rect {
    fill: var(--bg);
    stroke: var(--accent);
    stroke-width: 1.5;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .plot.is-visible .plot__nodes rect { opacity: 1; transition-delay: 1.4s; }

  .plot__caption {
    display: flex;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .plot__caption span:first-child { color: var(--accent); }

  @media (prefers-reduced-motion: reduce) {
    .plot__line { stroke-dashoffset: 0; transition: none; }
    .plot__nodes rect { opacity: 1; transition: none; }
  }
</style>
