---
// Vertical precision scale — a ruler edge with graduated ticks and numerals.
// Used to give text-led sections a balanced, on-brand right/left column.
const { from = 1, to = 6 } = Astro.props;
const count = to - from + 1;
const majors = Array.from({ length: count }, (_, i) => from + i);
// minor ticks between majors
const minors = Array.from({ length: (count - 1) * 4 }, (_, i) => i);
---
<div class="scale" data-reveal>
  <svg viewBox="0 0 120 520" class="scale__svg" role="img" aria-label="A precise measuring scale">
    <line class="scale__spine" x1="30" y1="20" x2="30" y2="500" />
    {minors.map((i) => {
      const y = 20 + ((500 - 20) / (minors.length)) * (i + 0.5);
      return <line class="scale__minor" x1="30" y1={y} x2="44" y2={y} />;
    })}
    {majors.map((n, i) => {
      const y = 20 + ((500 - 20) / (count - 1)) * i;
      return (
        <Fragment>
          <line class="scale__major" x1="30" y1={y} x2="62" y2={y} />
          <text class="scale__num" x="74" y={y + 5}>{`0${n}`}</text>
        </Fragment>
      );
    })}
  </svg>
</div>

<style>
  .scale { height: 100%; display: flex; align-items: stretch; }
  .scale__svg { height: 100%; width: auto; max-height: 560px; display: block; }
  .scale__spine { stroke: var(--line); stroke-width: 1; }
  .scale__minor { stroke: var(--accent); stroke-width: 1; opacity: 0.35; }
  .scale__major { stroke: var(--accent); stroke-width: 1.4; }
  .scale__num {
    fill: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 15px;
    letter-spacing: 0.06em;
  }
</style>
