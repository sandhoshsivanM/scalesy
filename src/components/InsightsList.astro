---
import { insights } from '../data/insights.js';
import { withBase } from '../lib/paths.js';

const { items = insights, showHeader = true, index = '06', limit = null } = Astro.props;
const list = limit ? items.slice(0, limit) : items;

const fmtDate = (iso) =>
  new Date(iso + 'T00:00:00Z').toLocaleDateString('en-US', {
    day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC',
  });
---
<section class="section insights" id="insights" aria-labelledby="insights-label">
  <div class="wrap">
    {showHeader && (
      <div class="insights__head" data-reveal>
        <p class="eyebrow eyebrow--index" id="insights-label">
          <span>{index}</span>&nbsp;&nbsp;Insights
        </p>
        <a href={withBase('/insights')} class="link-underline insights__all">All writing</a>
      </div>
    )}

    <ul class="insights__list">
      {list.map((a, i) => (
        <li class="insight" data-reveal style={`--reveal-delay:${i * 60}ms`}>
          <a class="insight__link" href={withBase(`/insights/${a.slug}`)}>
            <div class="insight__meta">
              <span class="insight__cat">{a.category}</span>
              <span class="insight__date">{fmtDate(a.date)}</span>
            </div>
            <h3 class="insight__title">{a.title}</h3>
            <p class="insight__excerpt text-secondary">{a.excerpt}</p>
            <span class="insight__read">Read — {a.readingTime}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .insights__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .insights__all { font-size: var(--step--1); color: var(--text-secondary); }

  .insights__list { list-style: none; margin: 0; padding: 0; }
  .insight { border-top: 1px solid var(--line-faint); }
  .insight:last-child { border-bottom: 1px solid var(--line-faint); }

  .insight__link {
    display: grid;
    grid-template-columns: minmax(9rem, 1fr) minmax(0, 3fr) minmax(6rem, auto);
    gap: clamp(1rem, 3vw, 3rem);
    align-items: start;
    padding-block: clamp(2rem, 4vw, 3rem);
    position: relative;
  }
  .insight__link::before {
    content: "";
    position: absolute;
    left: 0; top: -1px;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.55s var(--ease);
  }
  .insight:hover .insight__link::before,
  .insight__link:focus-visible::before { width: 100%; }

  .insight__meta { display: flex; flex-direction: column; gap: 0.4rem; }
  .insight__cat {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .insight__date { font-size: var(--step--1); color: var(--text-secondary); }

  .insight__title {
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    transition: transform 0.5s var(--ease);
  }
  .insight__excerpt {
    grid-column: 2;
    font-size: var(--step-0);
    line-height: 1.55;
    margin-top: 0.9rem;
    max-width: 54ch;
  }
  .insight__read {
    font-size: var(--step--1);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    justify-self: end;
    white-space: nowrap;
  }
  .insight:hover .insight__title { transform: translateX(8px); }

  @media (max-width: 820px) {
    .insight__link { grid-template-columns: 1fr; gap: 0.7rem; }
    .insight__excerpt { grid-column: 1; }
    .insight__read { justify-self: start; }
    .insight:hover .insight__title { transform: none; }
  }
</style>
