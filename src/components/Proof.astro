---
import { proof } from '../data/proof.js';
import GrowthPlot from './graphics/GrowthPlot.astro';
---
<section class="section proof" aria-label="How we work">
  <div class="wrap proof__inner">
    <div class="proof__text">
      <p class="eyebrow eyebrow--index" data-reveal><span>—</span>&nbsp;&nbsp;Proof</p>
      <h2 class="proof__title" data-reveal>Not louder marketing. A system you can measure.</h2>
      <ul class="proof__figures" data-reveal style="--reveal-delay:120ms">
        {proof.figures.map((f) => (
          <li class="figure">
            <span class="figure__value">{f.value}</span>
            <span class="figure__label">{f.label}</span>
            <span class="figure__sub text-secondary">{f.sub}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="proof__figure">
      <GrowthPlot />
    </div>
  </div>
</section>

<style>
  .proof__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }
  .proof__text { grid-column: 1 / 7; }
  .proof__title {
    margin-top: clamp(1.4rem, 3vw, 2.2rem);
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .proof__figures {
    list-style: none; margin: clamp(2rem, 4vw, 3rem) 0 0; padding: 0;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 3rem);
  }
  .figure { display: flex; flex-direction: column; gap: 0.3rem; padding-top: 1.1rem; border-top: 1px solid var(--line); }
  .figure__value {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 1.4rem + 3vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--accent);
  }
  .figure__label { font-size: var(--step-0); color: var(--text); margin-top: 0.3rem; }
  .figure__sub { font-size: var(--step--1); }

  .proof__figure { grid-column: 8 / -1; }

  @media (max-width: 900px) {
    .proof__text { grid-column: 1 / -1; }
    .proof__figure { grid-column: 1 / -1; margin-top: clamp(2.5rem, 6vw, 3.5rem); max-width: 26rem; }
  }
</style>
